# ==========================================
# LabCircle Environment Variables Template
# Copy this file to .env.local for local development.
# ==========================================

# 1. Firebase Client SDK (Public Variables)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# 2. Firebase Emulator Controls
# Set to 'true' to redirect Auth, Firestore, and Storage to local emulators
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# 3. Firebase Admin SDK (Server Variables)
# Required ONLY in production environment contexts.
# When NEXT_PUBLIC_USE_FIREBASE_EMULATOR is true, the Admin SDK routes automatically 
# without requiring service account keys.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 4. Payment Integrations
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxx
RAZORPAY_KEY_SECRET=razorpay_secret_xxxxxxx
