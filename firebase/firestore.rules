rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Default deny-all policy
    match /{document=**} {
      allow read, write: if false;
    }

    // Patients collection
    match /patients/{patientId} {
      allow read, write: if isOwner(patientId);
    }

    // Labs collection
    match /labs/{labId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.token.role == 'admin';
    }

    // Lab Reports collection
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (
        resource.data.patientId == request.auth.uid || 
        resource.data.labId == request.auth.uid ||
        request.auth.token.role == 'doctor'
      );
      allow write: if isAuthenticated() && (
        request.auth.token.role == 'lab_technician' ||
        request.auth.token.role == 'admin'
      );
    }
  }
}
